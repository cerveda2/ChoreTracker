rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isUserDocument(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function householdDoc(householdId) {
      return get(/databases/$(database)/documents/households/$(householdId));
    }

    function memberDoc(householdId, uid) {
      return get(/databases/$(database)/documents/households/$(householdId)/members/$(uid));
    }

    function householdDocExists(householdId) {
      return exists(/databases/$(database)/documents/households/$(householdId));
    }

    function memberDocExists(householdId, uid) {
      return exists(/databases/$(database)/documents/households/$(householdId)/members/$(uid));
    }

    function isHouseholdMember(householdId) {
      return isSignedIn() &&
        memberDocExists(householdId, request.auth.uid) &&
        memberDoc(householdId, request.auth.uid).data.active == true;
    }

    function isHouseholdOwner(householdId) {
      return isSignedIn() &&
        householdDocExists(householdId) &&
        householdDoc(householdId).data.ownerUserId == request.auth.uid;
    }

    function isSelfMemberWrite(householdId, memberId) {
      return isSignedIn() &&
        memberId == request.auth.uid &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.householdId == householdId;
    }

    function isOwnMembershipRecord() {
      return isSignedIn() &&
        resource.data.userId == request.auth.uid;
    }

    function canManageUserDocument(userId) {
      return isUserDocument(userId) ||
        (
          isSignedIn() &&
          request.resource.data.userId == userId &&
          request.resource.data.householdId != null &&
          isHouseholdOwner(request.resource.data.householdId)
        );
    }

    match /users/{userId} {
      allow read, delete: if isUserDocument(userId);
      allow create, update: if canManageUserDocument(userId);
    }

    // Required for collectionGroup("members") queries in resolveHouseholdId.
    // Firestore v2 does not extend nested match rules to collection group queries —
    // an explicit /{path=**}/members/{memberId} rule is mandatory.
    match /{path=**}/members/{memberId} {
      allow read: if isOwnMembershipRecord();
    }

    match /households/{householdId} {
      allow create: if isSignedIn() && request.resource.data.ownerUserId == request.auth.uid;
      allow read: if isHouseholdMember(householdId);
      allow update, delete: if isHouseholdOwner(householdId);

      match /members/{memberId} {
        allow read: if isHouseholdMember(householdId) || isOwnMembershipRecord();
        allow create: if isHouseholdOwner(householdId) ||
          isSelfMemberWrite(householdId, memberId);
        allow update: if isHouseholdOwner(householdId) ||
          isSelfMemberWrite(householdId, memberId);
        allow delete: if isHouseholdOwner(householdId);
      }

      match /chores/{choreId} {
        allow read: if isHouseholdMember(householdId);
        allow create, update, delete: if isHouseholdOwner(householdId);
      }

      match /completions/{completionId} {
        allow read: if isHouseholdMember(householdId);
        // Owner can create any completion (needed for full-snapshot sync where
        // the authenticated user may not be the original completion author).
        // Members can only create completions they authored.
        allow create: if isHouseholdOwner(householdId) ||
          (isHouseholdMember(householdId) && request.resource.data.createdByUserId == request.auth.uid);
        // Owner can update/delete any completion.
        // Members can update/delete completions they authored.
        allow update, delete: if isHouseholdOwner(householdId) ||
          (isHouseholdMember(householdId) && resource.data.createdByUserId == request.auth.uid);
      }

      match /invites/{inviteId} {
        allow read: if isHouseholdMember(householdId);
        allow create, update, delete: if isHouseholdOwner(householdId);
      }
    }
  }
}
